generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// comando $npx primas db push - Criar a tabela no banco de dados
// Comando $npx prisma pull - Sincronizae o schema.prisma com o banco de dados
// Comando $npx prisma migrate dev --name init create table user
model User {
  id        Int      @id @default(autoincrement())
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @default(USER)
  name      String
  email     String   @unique
  posts     Post[]

  @@map("users")
}

model Post {
  id      Int    @id @default(autoincrement())
  title   String
  sbtitle String
  userId  Int    @map("user_id")
  user    User   @relation(fields: [userId], references: [id])

  @@map("posts")
}
